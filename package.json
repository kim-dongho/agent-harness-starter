{
  "name": "@frontend-playground/agent-harness-starter",
  "version": "0.1.2",
  "description": "Scaffold projects with AI agent rules",
  "type": "module",
  "bin": {
    "agent-harness-starter": "./dist/cli.js",
    "create-ahs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stacks": "tsx scripts/test-stacks.ts",
    "test:frontend": "tsx scripts/test-stacks.ts frontend",
    "test:backend": "tsx scripts/test-stacks.ts backend",
    "test:blockchain": "tsx scripts/test-stacks.ts blockchain",
    "test:monorepo": "tsx scripts/test-stacks.ts monorepo",
    "test:clean": "tsx scripts/test-stacks.ts --clean",
    "test:docker": "tsx scripts/test-docker.ts",
    "test:docker:clean": "tsx scripts/test-docker.ts --clean",
    "publish:gitlab": "npm run build && npm publish --//gitlab.dtechlab.com/api/v4/projects/128/packages/npm/:_authToken=$GITLAB_FP_PROJECT_TOKEN",
    "semantic-release": "semantic-release"
  },
  "keywords": [
    "cli",
    "scaffold",
    "harness",
    "ai-agent"
  ],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "@frontend-playground:registry": "https://gitlab.dtechlab.com/api/v4/projects/128/packages/npm/"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^15.0.0",
    "fs-extra": "^11.3.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.3.2",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
